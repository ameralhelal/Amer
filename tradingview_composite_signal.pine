// ——— composite_signal.py ———
float score = 0.0

if not na(rsi)
    if rsi < 28
        score += 18
    else if rsi > 72
        score -= 18
    else if rsi < 42
        score += 7
    else if rsi > 58
        score -= 7

if not na(hist) and not na(macdDiff)
    if hist > 0 and macdDiff >= 0
        score += 12
    else if hist < 0 and macdDiff <= 0
        score -= 12
    else if macdDiff > 0
        score += 5
    else if macdDiff < 0
        score -= 5

if stDir == 1
    score += 14
else if stDir == -1
    score -= 14

if not na(adx) and not na(pdi) and not na(mdi)
    if adx >= 22
        if pdi > mdi + 1
            score += 10
        else if mdi > pdi + 1
            score -= 10
    else
        score *= 0.92

if close > 0 and not na(vwapC) and vwapC > 0
    if close >= vwapC
        score += 8
    else
        score -= 8

if cscore > 0
    w = math.max(-14.0, math.min(14.0, cscore * 2.8))
    score += w
else if cscore < 0
    w = math.max(-14.0, math.min(14.0, cscore * 2.8))
    score += w

if not na(stk) and not na(std) and stk > 0 and std > 0
    if stk < 25 and stk > std
        score += 6
    else if stk > 75 and std > stk
        score -= 6

score := math.max(-100.0, math.min(100.0, score))

ready = not na(rsi) and not na(macdLine) and not na(adx) and not na(stk)
plot(ready ? score : na, title="Score", color=score >= 14 ? color.new(color.lime, 0) : score <= -14 ? color.new(color.red, 0) : color.new(color.silver, 0), linewidth=2)

hline(0, "0", color=color.new(color.gray, 50))
hline(14, "+14", color=color.new(color.green, 80))
hline(-14, "-14", color=color.new(color.red, 80))
hline(38, "+38", color=color.new(color.green, 70))
hline(-38, "-38", color=color.new(color.red, 70))

bgcolor(
     ready and score >= 38 ? color.new(color.green, 88) :
     ready and score <= -38 ? color.new(color.red, 88) :
     ready and score >= 14 ? color.new(color.green, 93) :
     ready and score <= -14 ? color.new(color.red, 93) : na)

string lvl =
     score >= 38 ? "Strong buy" :
     score >= 14 ? "Buy" :
     score > -14 ? "Neutral" :
     score > -38 ? "Sell" : "Strong sell"

var table info = table.new(position.top_right, 1, 3, border_width=1)
if barstate.islast and ready
    table.cell(info, 0, 0, "المؤشر المركّب", text_color=color.white, bgcolor=color.new(color.black, 20), text_size=size.small)
    table.cell(info, 0, 1, str.tostring(score, "#0.1") + " — " + lvl, text_color=color.white, bgcolor=color.new(color.black, 35), text_size=size.small)
    table.cell(info, 0, 2, useCandlePatterns ? ("شموع: " + str.tostring(patNet)) : "شموع: —", text_color=color.new(color.silver, 0), bgcolor=color.new(color.black, 45), text_size=size.small)
