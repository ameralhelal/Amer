// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © مركّب مطابق تقريباً لمشروع التداول (composite_signal.py + websocket_manager.py)
//
// الاستخدام: TradingView → Pine Editor → لصق الكامل → Add to chart
//
// ملاحظات:
// - أنماط الشموع: منطق قريب من candlestick_patterns.py → detect_all (شمعة/2/3/5 + كيكر).
//   غير مضمّن: أنماط السعر الطويلة (_detect_chart_patterns) و Head & Shoulders / Inverse H&S.
// - VWAP الافتراضي = تراكمي من أول شمعة في الشارت (يشبه بافر الشموع الطويل)، وليس جلسة يومية.
// - لا يوجد market_info.trend في Pine (±4 في التطبيق).
// - اختلافات طفيفة محتملة في ADX/StochRSI بسبب تعريفات RMA/SMA بين المنصات.

//@version=5
// الاسم يظهر في قائمة المؤشرات وعنوان اللوحة — غيّره كما تشاء
indicator("المؤشر المركّب — من تطبيقي", shorttitle="مركّب_تطبيقي", overlay=false, precision=1, max_lines_count=64, max_labels_count=64)

// ——— مدخلات (نفس الأرقام الشائعة في websocket_manager) ———
groupRsi = "RSI (SMA على التغيّر)"
rsiLen = input.int(5, "نافذة RSI", minval=2, group=groupRsi)

groupMacd = "MACD"
macdFast = input.int(6, "سريع", group=groupMacd)
macdSlow = input.int(13, "بطيء", group=groupMacd)
macdSig = input.int(5, "إشارة", group=groupMacd)

groupAdx = "ADX / DI"
adxLen = input.int(7, "الفترة", minval=2, group=groupAdx)

groupSt = "Supertrend"
stMult = input.float(3.0, "المضاعف", group=groupSt)
stAtr = input.int(10, "ATR", minval=2, group=groupSt)

groupStoch = "Stoch RSI"
innerRsiLen = input.int(5, "RSI داخلي", minval=2, group=groupStoch)
stochLen = input.int(5, "نطاق Stoch على RSI", minval=2, group=groupStoch)
smoothK = input.int(3, "تنعيم K", minval=1, group=groupStoch)
smoothD = input.int(3, "تنعيم D", minval=1, group=groupStoch)

groupVwap = "VWAP"
vwapMode = input.string("Cumulative chart", "الوضع", options=["Cumulative chart", "Session VWAP (ta.vwap)"], group=groupVwap)

groupPat = "أنماط الشموع (candlestick_patterns.py)"
useCandlePatterns = input.bool(true, "دمج قراءة الشموع في الدرجة", group=groupPat)
showPatInData = input.bool(true, "إظهار فرق الشموع (+/−) في نافذة البيانات", group=groupPat)

// ——— RSI: متوسط آخر N لتغيّرات الإغلاق (كما في التطبيق) ———
f_sma_rsi(len) =>
    float ag = 0.0
    float al = 0.0
    for i = 0 to len - 1
        ch = close[i] - close[i + 1]
        ag := ag + math.max(ch, 0.0)
        al := al + math.max(-ch, 0.0)
    ag := ag / len
    al := al < 1e-10 ? 1e-10 : al
    100.0 - (100.0 / (1.0 + ag / al))

rsi = f_sma_rsi(rsiLen)

// ——— MACD ———
macdLine = ta.ema(close, macdFast) - ta.ema(close, macdSlow)
sigLine = ta.ema(macdLine, macdSig)
hist = macdLine - sigLine
macdDiff = macdLine - sigLine

// ——— Supertrend (مكتبة Pine؛ فترة/مضاعف كالتطبيق) ———
// اتجاه Supertrend كما في التطبيق: 1 إذا الإغلاق فوق الخط، −1 إذا تحته (لا نعتمد على قيمة الاتجاه من المكتبة)
stVal = ta.supertrend(stMult, stAtr)[0]
stDir = close > stVal ? 1 : -1

// ——— ADX ———
adx = ta.adx(adxLen)
pdi = ta.plusDI(adxLen)
mdi = ta.minusDI(adxLen)

// ——— VWAP ———
volNz = nz(volume, 0.0)
vwapCum = ta.cum(hlc3 * volNz) / math.max(ta.cum(volNz), 1e-9)
vwapSess = ta.vwap(hlc3)
vwapC = vwapMode == "Session VWAP (ta.vwap)" ? vwapSess : vwapCum

// ——— Stoch RSI (منطق قريب من websocket_manager) ———
rsiForStoch = ta.rsi(close, innerRsiLen)
rsil = ta.lowest(rsiForStoch, stochLen)
rsih = ta.highest(rsiForStoch, stochLen)
stochR = (rsiForStoch - rsil) / math.max(rsih - rsil, 1e-9) * 100.0
stk = ta.sma(stochR, smoothK)
std = ta.sma(stk, smoothD)

// ——— قراءة الشموع: مطابقة تقريبية لـ detect_all (الدرجة = #صعودي − #هابط كما في التطبيق) ———
f_bw(int sh) =>
    float o = open[sh]
    float h = high[sh]
    float l = low[sh]
    float c = close[sh]
    float body = math.abs(c - o)
    float rng = math.max(h - l, 1e-10)
    float upper = h - math.max(o, c)
    float lower = math.min(o, c) - l
    bool isBull = c > o
    [body, rng, upper, lower, isBull]

f_dir(int sh) =>
    close[sh] > open[sh] ? 1 : close[sh] < open[sh] ? -1 : 0

f_is_doji(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r > 0 and b / r <= 0.08

f_is_hammer(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 or b <= 0 ? false : (l >= 2.0 * b and u <= b * 0.4 and (ib or b / r < 0.35))

f_is_inv_hammer(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 or b <= 0 ? false : (u >= 2.0 * b and l <= b * 0.4)

f_is_shoot_star(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 or b <= 0 ? false : (u >= 2.0 * b and l <= b * 0.4)

f_is_dragfly(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 ? false : (b / r <= 0.1 and l >= r * 0.6 and u <= r * 0.1)

f_is_grave(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 ? false : (b / r <= 0.1 and u >= r * 0.6 and l <= r * 0.1)

f_is_maru_bull(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    not ib or r <= 0 ? false : (b >= r * 0.9 and u <= r * 0.1 and l <= r * 0.1)

f_is_maru_bear(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    ib or r <= 0 ? false : (b >= r * 0.9 and u <= r * 0.1 and l <= r * 0.1)

f_is_spin_top(int sh) =>
    [b, r, u, l, ib] = f_bw(sh)
    r <= 0 ? false : (b / r >= 0.1 and b / r <= 0.35 and u >= r * 0.2 and l >= r * 0.2)

// c1 أقدم من c2 (في Pine: c1=[1], c2=[0])
f_bull_eng() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float o2 = open[0]
    float c2 = close[0]
    not bull1 and bull2 and o2 <= c1 and c2 >= o1 and c2 > o2 and o2 < o1

f_bear_eng() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float o2 = open[0]
    float c2 = close[0]
    bull1 and not bull2 and o2 >= c1 and c2 <= o1 and c2 < o2 and o2 > o1

f_bull_harami() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float o2 = open[0]
    float c2 = close[0]
    b1 <= 0 ? false : (not bull1 and bull2 and b2 < b1 and o2 > c1 and c2 < o1)

f_bear_harami() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float o2 = open[0]
    float c2 = close[0]
    b1 <= 0 ? false : (bull1 and not bull2 and b2 < b1 and o2 < c1 and c2 > o1)

f_piercing() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float l1_ = low[1]
    float o2 = open[0]
    float c2 = close[0]
    float mid1 = (o1 + c1) / 2.0
    not bull1 and bull2 and o2 < l1_ and c2 > mid1 and c2 < o1

f_dark_cloud() =>
    [b1, r1, u1, l1, bull1] = f_bw(1)
    [b2, r2, u2, l2, bull2] = f_bw(0)
    float o1 = open[1]
    float c1 = close[1]
    float h1 = high[1]
    float o2 = open[0]
    float c2 = close[0]
    float mid1 = (o1 + c1) / 2.0
    bull1 and not bull2 and o2 > h1 and c2 < mid1 and c2 > o1

f_tweezer_bot() =>
    float l1 = low[1]
    float l2 = low[0]
    math.abs(l1 - l2) / (l1 + 1e-9) <= 0.002

f_tweezer_top() =>
    float h1 = high[1]
    float h2 = high[0]
    math.abs(h1 - h2) / (h1 + 1e-9) <= 0.002

// ثلاث شمعات: الأقدم [2]، الأحدث [0]
f_morning_star() =>
    [b1, r1, u1, l1, bull1] = f_bw(2)
    [b2, r2, u2, l2, bull2] = f_bw(1)
    [b3, r3, u3, l3, bull3] = f_bw(0)
    float o1 = open[2]
    float c1 = close[2]
    float c3 = close[0]
    r1 <= 0 or r3 <= 0 ? false : (not bull1 and (b2 / (r2 + 1e-9) <= 0.35) and bull3 and c3 > (o1 + c1) / 2.0)

f_evening_star() =>
    [b1, r1, u1, l1, bull1] = f_bw(2)
    [b2, r2, u2, l2, bull2] = f_bw(1)
    [b3, r3, u3, l3, bull3] = f_bw(0)
    float o1 = open[2]
    float c1 = close[2]
    float c3 = close[0]
    r1 <= 0 or r3 <= 0 ? false : (bull1 and (b2 / (r2 + 1e-9) <= 0.35) and not bull3 and c3 < (o1 + c1) / 2.0)

f_three_white() =>
    [b1, r1, u1, l1, bull1] = f_bw(2)
    [b2, r2, u2, l2, bull2] = f_bw(1)
    [b3, r3, u3, l3, bull3] = f_bw(0)
    float cl1 = close[2]
    float cl2 = close[1]
    float cl3 = close[0]
    bull1 and bull2 and bull3 and cl1 < cl2 and cl2 < cl3

f_three_black() =>
    [b1, r1, u1, l1, bull1] = f_bw(2)
    [b2, r2, u2, l2, bull2] = f_bw(1)
    [b3, r3, u3, l3, bull3] = f_bw(0)
    float cl1 = close[2]
    float cl2 = close[1]
    float cl3 = close[0]
    not bull1 and not bull2 and not bull3 and cl1 > cl2 and cl2 > cl3

f_bull_kicker() =>
    f_dir(1) == -1 and f_dir(0) == 1 and open[0] > high[1]

f_bear_kicker() =>
    f_dir(1) == 1 and f_dir(0) == -1 and open[0] < low[1]

// a أقدم من b (مثال: ابتلاع بين [2] و[1])
f_bull_eng_ab(int a, int b) =>
    [b1, r1, u1, l1, bull1] = f_bw(a)
    [b2, r2, u2, l2, bull2] = f_bw(b)
    float o1 = open[a]
    float c1 = close[a]
    float o2 = open[b]
    float c2 = close[b]
    not bull1 and bull2 and o2 <= c1 and c2 >= o1 and c2 > o2 and o2 < o1

f_bear_eng_ab(int a, int b) =>
    [b1, r1, u1, l1, bull1] = f_bw(a)
    [b2, r2, u2, l2, bull2] = f_bw(b)
    float o1 = open[a]
    float c1 = close[a]
    float o2 = open[b]
    float c2 = close[b]
    bull1 and not bull2 and o2 >= c1 and c2 <= o1 and c2 < o2 and o2 > o1

f_bull_harami_ab(int a, int b) =>
    [b1, r1, u1, l1, bull1] = f_bw(a)
    [b2, r2, u2, l2, bull2] = f_bw(b)
    float o1 = open[a]
    float c1 = close[a]
    float o2 = open[b]
    float c2 = close[b]
    b1 <= 0 ? false : (not bull1 and bull2 and b2 < b1 and o2 > c1 and c2 < o1)

f_bear_harami_ab(int a, int b) =>
    [b1, r1, u1, l1, bull1] = f_bw(a)
    [b2, r2, u2, l2, bull2] = f_bw(b)
    float o1 = open[a]
    float c1 = close[a]
    float o2 = open[b]
    float c2 = close[b]
    b1 <= 0 ? false : (bull1 and not bull2 and b2 < b1 and o2 < c1 and c2 > o1)

f_three_inside_up() =>
    f_bull_harami_ab(2, 1) and f_dir(0) == 1 and close[0] > open[2]

f_three_inside_down() =>
    f_bear_harami_ab(2, 1) and f_dir(0) == -1 and close[0] < open[2]

f_three_outside_up() =>
    f_bull_eng_ab(2, 1) and f_dir(0) == 1 and close[0] > close[1]

f_three_outside_down() =>
    f_bear_eng_ab(2, 1) and f_dir(0) == -1 and close[0] < close[1]

f_aband_bull() =>
    f_is_doji(1) and f_dir(2) == -1 and high[1] < low[2] and f_dir(0) == 1 and open[0] > high[1]

f_aband_bear() =>
    f_is_doji(1) and f_dir(2) == 1 and low[1] > high[2] and f_dir(0) == -1 and open[0] < low[1]

f_bull_tasuki() =>
    f_dir(2) == 1 and f_dir(1) == 1 and low[1] > high[2] and f_dir(0) == -1 and close[0] > high[2]

f_bear_tasuki() =>
    f_dir(2) == -1 and f_dir(1) == -1 and high[1] < low[2] and f_dir(0) == 1 and close[0] < low[2]

f_ok_rising_mid(int sh) =>
    f_dir(sh) <= 0 and high[sh] <= high[4] and low[sh] >= low[4]

f_ok_falling_mid(int sh) =>
    f_dir(sh) >= 0 and high[sh] <= high[4] and low[sh] >= low[4]

f_rising_three() =>
    f_dir(4) == 1 and f_dir(0) == 1 and close[0] > close[4] and f_ok_rising_mid(3) and f_ok_rising_mid(2) and f_ok_rising_mid(1)

f_falling_three() =>
    f_dir(4) == -1 and f_dir(0) == -1 and close[0] < close[4] and f_ok_falling_mid(3) and f_ok_falling_mid(2) and f_ok_falling_mid(1)

// صافي الأنماط: len(bullish) − len(bearish) كما في candlestick_patterns.detect_all
// ملاحظة Pine: داخل الدوال لا تستخدم += — استخدم := مع جمع صريح وإلا يفشل التجميع.
f_pattern_net_score() =>
    int bull = 0
    int bear = 0
    if bar_index >= 0
        if f_is_hammer(0)
            bull := bull + 1
        if f_is_hammer(0)
            bear := bear + 1
        if f_is_inv_hammer(0)
            bull := bull + 1
        if f_is_shoot_star(0)
            bear := bear + 1
        if f_is_dragfly(0)
            bull := bull + 1
        if f_is_grave(0)
            bear := bear + 1
        if f_is_maru_bull(0)
            bull := bull + 1
        if f_is_maru_bear(0)
            bear := bear + 1
    if bar_index >= 1
        if f_bull_eng()
            bull := bull + 1
        if f_bear_eng()
            bear := bear + 1
        if f_bull_harami()
            bull := bull + 1
        if f_bear_harami()
            bear := bear + 1
        if f_piercing()
            bull := bull + 1
        if f_dark_cloud()
            bear := bear + 1
        if f_tweezer_bot()
            bull := bull + 1
        if f_tweezer_top()
            bear := bear + 1
        if f_bull_kicker()
            bull := bull + 1
        if f_bear_kicker()
            bear := bear + 1
    if bar_index >= 2
        if f_morning_star()
            bull := bull + 1
        if f_evening_star()
            bear := bear + 1
        if f_three_white()
            bull := bull + 2
        if f_three_black()
            bear := bear + 1
        if f_three_inside_up()
            bull := bull + 1
        if f_three_inside_down()
            bear := bear + 1
        if f_three_outside_up()
            bull := bull + 1
        if f_three_outside_down()
            bear := bear + 1
        if f_aband_bull()
            bull := bull + 1
        if f_aband_bear()
            bear := bear + 1
        if f_bull_tasuki()
            bull := bull + 1
        if f_bear_tasuki()
            bear := bear + 1
    if bar_index >= 4
        if f_rising_three()
            bull := bull + 1
        if f_falling_three()
            bear := bear + 1
    bull - bear

patNet = f_pattern_net_score()
float cscore = useCandlePatterns ? float(patNet) : 0.0

plot(showPatInData ? patNet : na, title="PatNet candles", display=display.data_window)

</think>
